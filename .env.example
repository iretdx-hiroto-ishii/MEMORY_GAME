# Copy to .env and fill in values. Never commit .env.
# See docs/APP_STORE_RELEASE.md for AdMob / App Store setup.

# App environment: development | production
VITE_APP_ENV=development

# Public URL of privacy policy (required for App Store Connect & AdMob)
# Production example: https://memory-game-three-mauve.vercel.app/privacy-policy.html
VITE_PRIVACY_POLICY_URL=

# AdMob (iOS) — use in app code when integrating ads; also set GADApplicationIdentifier in ios/App/App/Info.plist
# VITE_ADMOB_APP_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
# VITE_ADMOB_BANNER_UNIT_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/zzzzzzzzzz

# Optional: web demo (AdSense) — publisher ID also goes in public/ads.txt
# VITE_ADSENSE_PUBLISHER_ID=pub-xxxxxxxxxxxxxxxx
